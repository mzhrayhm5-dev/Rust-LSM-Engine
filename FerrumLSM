/// Unified error type — zero allocation on hot paths.
#[derive(Debug, thiserror::Error)]
pub enum MonitorError {
    /// Network interface not found.
    #[error("interface not found: {0}")]
    InterfaceNotFound(String),

    /// Packet size exceeds maximum allowed.
    #[error("packet too large: {size} bytes (max {max})")]
    PacketTooLarge {
        /// Actual packet size.
        size: usize,
        /// Maximum allowed size.
        max:  usize,
    },

    /// Ring buffer capacity exceeded.
    #[error("ring buffer full: capacity={capacity}")]
    RingBufferFull {
        /// Buffer capacity in packets.
        capacity: usize,
    },

    /// Invalid IP address format.
    #[error("invalid address: {0}")]
    InvalidAddress(String),

    /// Rate limiter rejected the packet.
    #[error("rate limit exceeded: {pps} pps")]
    RateLimitExceeded {
        /// Current packets per second.
        pps: u64,
    },

    /// I/O failure.
    #[error("io error: {0}")]
    Io(#[from] std::io::Error),
}

// =============================================================================
//  MODULE: packet — Zero-copy packet representation
// =============================================================================

/// Zero-copy packet parsing and representation.
///
/// # Why zero-copy?
/// Network packets arrive in kernel-allocated buffers. Copying them to
/// userspace doubles memory bandwidth and adds ~500ns of latency on a
/// 10Gbps NIC. We use `Arc<[u8]>` slices to share the buffer without
/// copying — critical for HFT tick-to-trade pipelines.
pub mod packet {
    use std::sync::Arc;
    use super::MonitorError;

    // ── Protocol constants ────────────────────────────────────────────────────

    /// IPv4 protocol number.
    pub const PROTO_IPV4: u8 = 0x08;
    /// IPv6 protocol number.
    pub const PROTO_IPV6: u8 = 0x86;
    /// TCP protocol number.
    pub const PROTO_TCP:  u8 = 6;
    /// UDP protocol number.
    pub const PROTO_UDP:  u8 = 17;
    /// ICMP protocol number.
    pub const PROTO_ICMP: u8 = 1;
    /// Maximum Ethernet frame size (jumbo frames).
    pub const MAX_PACKET_SIZE: usize = 9_000;

    // ── Protocol ─────────────────────────────────────────────────────────────

    /// Transport-layer protocol.
    #[repr(u8)]
    #[non_exhaustive]
    #[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
    pub enum Protocol {
        /// Transmission Control Protocol.
        Tcp  = PROTO_TCP,
        /// User Datagram Protocol.
        Udp  = PROTO_UDP,
        /// Internet Control Message Protocol.
        Icmp = PROTO_ICMP,
        /// Unknown or unsupported protocol.
        Unknown = 255,
    }

    impl From<u8> for Protocol {
        fn from(v: u8) -> Self {
            match v {
                PROTO_TCP  => Self::Tcp,
                PROTO_UDP  => Self::Udp,
                PROTO_ICMP => Self::Icmp,
                _          => Self::Unknown,
            }
        }
    }

    // ── PacketMeta ────────────────────────────────────────────────────────────

    /// Parsed packet metadata — extracted without copying the payload.
    ///
    /// # Cache-Line Layout
    /// Aligned to 64 bytes so the hot classification path touches exactly
    /// one cache line.
    #[repr(C, align(64))]
    #[derive(Debug, Clone)]
    pub struct PacketMeta {
        /// Source IPv4 address (network byte order).
        pub src_ip:   u32,
        /// Destination IPv4 address (network byte order).
        pub dst_ip:   u32,
        /// Source port.
        pub src_port: u16,
        /// Destination port.
        pub dst_port: u16,
        /// Transport protocol.
        pub protocol: Protocol,
        /// Total packet length in bytes.
        pub length:   u16,
        /// Kernel arrival timestamp in nanoseconds since boot.
        pub ts_ns:    u64,
        /// Interface index the packet arrived on.
        pub ifindex:  u32,
        /// TCP flags (SYN=0x02, ACK=0x10, FIN=0x01, RST=0x04).
        pub tcp_flags: u8,
        /// Explicit padding to reach 64 bytes.
        _pad: [u8; 25],
    }

    // Compile-time layout assertion.
    const _: () = assert!(
        std::mem::size_of::<PacketMeta>() == 64,
        "PacketMeta must be exactly 64 bytes"
    );

    impl PacketMeta {
        /// Parses a raw Ethernet frame into `PacketMeta`.
        ///
        /// # Why manual parsing?
        /// Using a crate like `pnet` adds 2-3 allocations per packet.
        /// Manual parsing is zero-allocation and ~10x faster on the hot path.
        ///
        /// # Errors
        /// Returns [`MonitorError::PacketTooLarge`] if frame exceeds limit.
        /// Returns [`MonitorError::InvalidAddress`] if the frame is malformed.
        pub fn parse(frame: &[u8], ts_ns: u64, ifindex: u32) -> Result<Self, MonitorError> {
            if frame.len() > MAX_PACKET_SIZE {
                return Err(MonitorError::PacketTooLarge {
                    size: frame.len(),
                    max:  MAX_PACKET_SIZE,
                });
            }
            // Minimum Ethernet + IPv4 + TCP header = 14 + 20 + 20 = 54 bytes
            if frame.len() < 34 {
                return Err(MonitorError::InvalidAddress("frame too short".into()));
            }

            // Ethernet header: dst(6) + src(6) + ethertype(2)
            let ethertype = u16::from_be_bytes([frame[12], frame[13]]);
            if ethertype != 0x0800 {
                // Only IPv4 for now
                return Err(MonitorError::InvalidAddress("non-IPv4 frame".into()));
            }

            // IPv4 header starts at offset 14
            let ip = &frame[14..];
            let ihl = (ip[0] & 0x0f) as usize * 4;
            if ip.len() < ihl {
                return Err(MonitorError::InvalidAddress("truncated IP header".into()));
            }

            let src_ip   = u32::from_be_bytes([ip[12], ip[13], ip[14], ip[15]]);
            let dst_ip   = u32::from_be_bytes([ip[16], ip[17], ip[18], ip[19]]);
            let protocol = Protocol::from(ip[9]);
            let length   = u16::from_be_bytes([ip[2], ip[3]]);

            let transport = &ip[ihl..];
            let (src_port, dst_port, tcp_flags) = if transport.len() >= 4 {
                let sp = u16::from_be_bytes([transport[0], transport[1]]);
                let dp = u16::from_be_bytes([transport[2], transport[3]]);
                let flags = if protocol == Protocol::Tcp && transport.len() >= 14 {
                    transport[13]
                } else {
                    0
                };
                (sp, dp, flags)
            } else {
                (0, 0, 0)
            };

            Ok(Self {
                src_ip,
                dst_ip,
                src_port,
                dst_port,
                protocol,
                length,
                ts_ns,
                ifindex,
                tcp_flags,
                _pad: [0u8; 25],
            })
        }

        /// Returns `true` if this is a TCP SYN packet (new connection attempt).
        #[inline(always)]
        #[must_use]
        pub fn is_syn(&self) -> bool {
            self.protocol == Protocol::Tcp && (self.tcp_flags & 0x02) != 0
        }

        /// Returns `true` if this is a TCP RST packet.
        #[inline(always)]
        #[must_use]
        pub fn is_rst(&self) -> bool {
            self.protocol == Protocol::Tcp && (self.tcp_flags & 0x04) != 0
        }

        /// Formats the source IP as a dotted-decimal string — zero allocation.
        #[must_use]
        pub fn src_ip_str(&self) -> [u8; 15] {
            ip_to_str(self.src_ip)
        }

        /// Formats the destination IP as a dotted-decimal string.
        #[must_use]
        pub fn dst_ip_str(&self) -> [u8; 15] {
            ip_to_str(self.dst_ip)
        }
    }

    /// Zero-allocation IPv4 → dotted-decimal conversion.
    fn ip_to_str(ip: u32) -> [u8; 15] {
        let mut buf = [b' '; 15];
        let octets = ip.to_be_bytes();
        let mut pos = 0usize;
        for (i, &oct) in octets.iter().enumerate() {
            if oct >= 100 { buf[pos] = b'0' + oct / 100;       pos += 1; }
            if oct >= 10  { buf[pos] = b'0' + (oct % 100) / 10; pos += 1; }
            buf[pos] = b'0' + oct % 10; pos += 1;
            if i < 3 { buf[pos] = b'.'; pos += 1; }
        }
        buf
    }

    // ── Packet ────────────────────────────────────────────────────────────────

    /// A network packet with zero-copy payload.
    #[derive(Debug, Clone)]
    pub struct Packet {
        /// Parsed metadata.
        pub meta:    PacketMeta,
        /// Raw payload — shared without copying via `Arc`.
        pub payload: Arc<[u8]>,
    }

    impl Packet {
        /// Constructs a packet from a raw frame.
        ///
        /// # Errors
        /// Propagates errors from [`PacketMeta::parse`].
        pub fn from_frame(
            frame:   &[u8],
            ts_ns:   u64,
            ifindex: u32,
        ) -> Result<Self, MonitorError> {
            let meta    = PacketMeta::parse(frame, ts_ns, ifindex)?;
            let payload = Arc::from(frame);
            Ok(Self { meta, payload })
        }

        /// Payload length in bytes.
        #[inline(always)]
        #[must_use]
        pub fn len(&self) -> usize { self.payload.len() }

        /// `true` if the payload is empty.
        #[inline(always)]
        #[must_use]
        pub fn is_empty(&self) -> bool { self.payload.is_empty() }
    }
}

// =============================================================================
//  MODULE: ring — Lock-free SPSC ring buffer
// =============================================================================

/// Single-Producer Single-Consumer lock-free ring buffer.
///
/// # Why SPSC?
/// eBPF programs run in kernel context (single writer per CPU).
/// The userspace consumer is a single thread per ring.
/// SPSC eliminates all CAS loops — just two atomic loads/stores.
pub mod ring {
    use std::sync::{
        atomic::{AtomicUsize, Ordering},
        Arc,
    };

    use super::{packet::Packet, MonitorError};

    // ── RingBuffer ────────────────────────────────────────────────────────────

    /// Lock-free SPSC ring buffer for packets.
    ///
    /// # Memory Layout
    /// `head` and `tail` are on separate cache lines to prevent false sharing
    /// between the producer (kernel eBPF) and consumer (userspace).
    pub struct RingBuffer {
        /// Packet slots — pre-allocated, never reallocated.
        slots:    Box<[Option<Packet>]>,
        /// Write index — updated only by the producer.
        head:     AtomicUsize,
        /// Read index — updated only by the consumer.
        tail:     AtomicUsize,
        /// Buffer capacity (power of two).
        capacity: usize,
        /// Bitmask = capacity − 1 for O(1) wrap-around.
        mask:     usize,
    }

    impl std::fmt::Debug for RingBuffer {
        fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
            f.debug_struct("RingBuffer")
                .field("capacity", &self.capacity)
                .field("len",      &self.len())
                .finish()
        }
    }

    impl RingBuffer {
        /// Constructs a ring buffer with `capacity` slots.
        ///
        /// # Why power-of-two?
        /// `index & mask` is one instruction vs `index % capacity` (division).
        ///
        /// # Errors
        /// Returns [`MonitorError::RingBufferFull`] if `capacity == 0`.
        pub fn new(capacity: usize) -> Result<Arc<Self>, MonitorError> {
            if capacity == 0 {
                return Err(MonitorError::RingBufferFull { capacity: 0 });
            }
            let cap = capacity.next_power_of_two();
            let slots = (0..cap).map(|_| None).collect::<Vec<_>>().into_boxed_slice();
            Ok(Arc::new(Self {
                slots,
                head:     AtomicUsize::new(0),
                tail:     AtomicUsize::new(0),
                capacity: cap,
                mask:     cap - 1,
            }))
        }

        /// Pushes a packet into the ring buffer.
        ///
        /// # Why `Release` on head store?
        /// Ensures the slot write is visible to the consumer before the
        /// head index update — no explicit fence needed.
        ///
        /// # Errors
        /// Returns [`MonitorError::RingBufferFull`] if the buffer is full.
        pub fn push(&self, pkt: Packet) -> Result<(), MonitorError> {
            let head = self.head.load(Ordering::Relaxed);
            let next = (head + 1) & self.mask;
            if next == self.tail.load(Ordering::Acquire) {
                return Err(MonitorError::RingBufferFull { capacity: self.capacity });
            }
            // SAFETY: `head & mask < capacity`, slots is pre-allocated.
            // Only the producer writes to `head`, so no aliasing.
            unsafe {
                let slot = &self.slots[head] as *const Option<Packet> as *mut Option<Packet>;
                slot.write(Some(pkt));
            }
            self.head.store(next, Ordering::Release);
            Ok(())
        }

        /// Pops a packet from the ring buffer.
        ///
        /// Returns `None` if the buffer is empty.
        #[must_use]
        pub fn pop(&self) -> Option<Packet> {
            let tail = self.tail.load(Ordering::Relaxed);
            if tail == self.head.load(Ordering::Acquire) {
                return None;
            }
            // SAFETY: `tail & mask < capacity`, only consumer reads from tail.
            let pkt = unsafe {
                let slot = &self.slots[tail] as *const Option<Packet> as *mut Option<Packet>;
                slot.replace(None)
            };
            self.tail.store((tail + 1) & self.mask, Ordering::Release);
            pkt.flatten()
        }

        /// Number of packets currently in the buffer.
        #[must_use]
        pub fn len(&self) -> usize {
            let head = self.head.load(Ordering::Acquire);
            let tail = self.tail.load(Ordering::Acquire);
            (head.wrapping_sub(tail)) & self.mask
        }

        /// `true` if the buffer contains no packets.
        #[must_use]
        pub fn is_empty(&self) -> bool { self.len() == 0 }

        /// Buffer capacity in packets.
        #[must_use]
        pub fn capacity(&self) -> usize { self.capacity }
    }
}

// =============================================================================
//  MODULE: classifier — Zero-allocation packet classifier
// =============================================================================

/// Rule-based packet classifier with O(1) lookup.
pub mod classifier {
    use std::collections::HashMap;
    use super::packet::{Packet, Protocol};

    // ── Action ────────────────────────────────────────────────────────────────

    /// Action to take on a matched packet.
    #[repr(u8)]
    #[non_exhaustive]
    #[derive(Debug, Clone, Copy, PartialEq, Eq)]
    pub enum Action {
        /// Allow the packet through.
        Allow = 0,
        /// Drop the packet silently.
        Drop  = 1,
        /// Log the packet and allow.
        Log   = 2,
        /// Mirror to analysis pipeline.
        Mirror = 3,
    }

    // ── Rule ─────────────────────────────────────────────────────────────────

    /// A single classification rule.
    #[derive(Debug, Clone)]
    pub struct Rule {
        /// Source IP to match (0 = wildcard).
        pub src_ip:   u32,
        /// Destination port to match (0 = wildcard).
        pub dst_port: u16,
        /// Protocol to match.
        pub protocol: Option<Protocol>,
        /// Action to take on match.
        pub action:   Action,
        /// Rule priority — higher wins on conflict.
        pub priority: u32,
    }

    // ── Classifier ────────────────────────────────────────────────────────────

    /// O(1) packet classifier backed by hash maps.
    ///
    /// # Why HashMap instead of a tree?
    /// For HFT classification, O(1) average-case beats O(log n) tree
    /// traversal when rule counts are small (< 10,000).
    #[derive(Debug, Default)]
    pub struct Classifier {
        /// Port-based rules: dst_port → Rule.
        port_rules: HashMap<u16, Rule>,
        /// IP-based rules: src_ip → Rule.
        ip_rules:   HashMap<u32, Rule>,
        /// Default action when no rule matches.
        default:    Action,
    }

    impl Classifier {
        /// Creates a new classifier with a default action.
        #[must_use]
        pub fn new(default: Action) -> Self {
            Self { port_rules: HashMap::new(), ip_rules: HashMap::new(), default }
        }

        /// Adds a rule to the classifier.
        pub fn add_rule(&mut self, rule: Rule) {
            if rule.dst_port != 0 {
                self.port_rules
                    .entry(rule.dst_port)
                    .and_modify(|e| { if rule.priority > e.priority { *e = rule.clone(); } })
                    .or_insert(rule.clone());
            }
            if rule.src_ip != 0 {
                self.ip_rules
                    .entry(rule.src_ip)
                    .and_modify(|e| { if rule.priority > e.priority { *e = rule.clone(); } })
                    .or_insert(rule);
            }
        }

        /// Classifies a packet and returns the action to take.
        ///
        /// Port rules take precedence over IP rules.
        #[inline]
        #[must_use]
        pub fn classify(&self, pkt: &Packet) -> Action {
            // Check port rules first (higher specificity)
            if let Some(rule) = self.port_rules.get(&pkt.meta.dst_port) {
                if rule.protocol.map_or(true, |p| p == pkt.meta.protocol) {
                    return rule.action;
                }
            }
            // Fall back to IP rules
            if let Some(rule) = self.ip_rules.get(&pkt.meta.src_ip) {
                return rule.action;
            }
            self.default
        }
    }
}

